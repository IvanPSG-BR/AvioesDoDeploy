---
const year = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const isManifesto = currentPath.includes('/manifesto');
const basePath = isManifesto ? '../' : './';
---

<footer class="border-t border-slate-100 dark:border-slate-800 bg-white dark:bg-slate-900 py-10 sm:py-12">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 mb-8 sm:mb-10">
      <!-- Brand -->
      <div>
        <a href={basePath} class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-50 mb-3">
          <img src={`${basePath}favicon.webp`} alt="Logo Aviões do Deploy" class="w-6 h-6 object-contain rounded-full" />
          Aviões do Deploy
        </a>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
          Time pequeno, ideias grandes. Aprendemos na marra e construímos soluções leves.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-50 mb-3">Links úteis</h3>
        <ul class="space-y-2 text-sm text-slate-500 dark:text-slate-400">
          <li><a href={basePath} class="hover:text-slate-900 dark:hover:text-slate-100 transition-colors">Início</a></li>
          <li><a href={`${basePath}manifesto`} class="hover:text-slate-900 dark:hover:text-slate-100 transition-colors">Manifesto</a></li>
          <li><a href={`${basePath}#projetos`} class="hover:text-slate-900 dark:hover:text-slate-100 transition-colors">Projetos</a></li>
          <li><a href="#como-participar" class="hover:text-slate-900 dark:hover:text-slate-100 transition-colors">Como participar</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-50 mb-3">Comunidade</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://github.com/avioes-do-deploy" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
              <i class="bi bi-github" aria-hidden="true"></i>
              GitHub
            </a>
          </li>
          <li>
            <a href="https://discord.gg/Pbmssyrv" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
              <i class="bi bi-chat-square-text" aria-hidden="true"></i>
              Discord
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-slate-100 dark:border-slate-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-slate-400 dark:text-slate-500">
      <p>© {year} Aviões do Deploy. Conteúdo sob licença MIT.</p>
      <p class="font-mono-highlight">
        Feito com ✈ e <span class="text-yellow-500">muito deploy</span>
      </p>
    </div>
  </div>
</footer>
